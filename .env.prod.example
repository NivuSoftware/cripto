# ============================================================
# PRODUCCION — Copiar a .env.prod y completar los valores
# NUNCA subir .env.prod al repositorio
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=cripto_db
POSTGRES_USER=cripto_user
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO_MIN_20_CHARS

# --- Flask ---
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIAR_POR_CLAVE_ALEATORIA_64_CHARS
FRONTEND_ORIGIN=https://hablemoscripto.com

# --- Admin seeder ---
ADMIN_EMAIL=admin@hablemoscripto.com
ADMIN_PASSWORD=CAMBIAR_POR_PASSWORD_ADMIN_SEGURO

# --- Cookies de sesion ---
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=true

# --- Email (Gmail SMTP) ---
EMAIL_ADDRESS=tucuenta@gmail.com
# App Password de Gmail (no la contrasena normal):
# Cuenta Google -> Seguridad -> Verificacion en 2 pasos -> Contrasenas de aplicaciones
EMAIL_PASSWORD=CAMBIAR_POR_APP_PASSWORD_GMAIL_16_CHARS
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
MAIL_SENDER=Hablemos Cripto <tucuenta@gmail.com>
MAIL_RECIPIENT=correo_donde_llegan_contactos@gmail.com

# --- Frontend build ---
VITE_SITE_URL=https://hablemoscripto.com
